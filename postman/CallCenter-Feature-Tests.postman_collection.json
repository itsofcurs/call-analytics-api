  "item": [
    {
      "name": "00 - Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Health endpoint is up', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('Health status is ok', function () {",
              "  pm.expect(body.status).to.eql('ok');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "01 - Analyze Audio (Hinglish/Tanglish) - Queue",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "{{apiKey}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/analyze-audio",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "analyze-audio"
          ]
        },
        "description": "Attach MP3/WAV sample call in Hinglish or Tanglish."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Audio queued', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.test('task_id exists', function () {",
              "  pm.expect(body.task_id).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.environment.set('taskId', body.task_id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 - Poll Job Status",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "{{apiKey}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/jobs/{{taskId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "jobs",
            "{{taskId}}"
          ]
        },
        "description": "Run repeatedly until status=success."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Poll returns 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "const allowed = ['pending', 'running', 'success', 'failure'];",
              "pm.test('Status is valid', function () {",
              "  pm.expect(allowed).to.include(body.status);",
              "});",
              "",
              "if (body.status === 'success') {",
              "  const r = body.result || {};",
              "  pm.test('STT transcript exists', function () {",
              "    pm.expect(r.transcript).to.be.a('string').and.not.empty;",
              "  });",
              "  pm.test('Summary exists', function () {",
              "    pm.expect(r.summary).to.be.a('string').and.not.empty;",
              "  });",
              "  pm.test('Sentiment exists', function () {",
              "    pm.expect(r.sentiment).to.be.a('string').and.not.empty;",
              "  });",
              "  pm.test('SOP output exists', function () {",
              "    pm.expect(r.sop).to.be.an('object');",
              "  });",
              "  pm.test('Payment categorization exists', function () {",
              "    pm.expect(r.payments).to.be.an('object');",
              "    pm.expect(r.payments.counts).to.be.an('object');",
              "    pm.expect(r.payments.counts).to.have.property('emi');",
              "    pm.expect(r.payments.counts).to.have.property('full');",
              "    pm.expect(r.payments.counts).to.have.property('partial');",
              "    pm.expect(r.payments.counts).to.have.property('down');",
              "  });",
              "  pm.test('Rejection analysis exists', function () {",
              "    pm.expect(r.rejections).to.be.an('object');",
              "  });",
              "  pm.test('Entities extracted', function () {",
              "    pm.expect(r.entities).to.be.an('array');",
              "  });",
              "}",
              "",
              "if (body.status === 'failure') {",
              "  pm.test('Failure has error', function () {",
              "    pm.expect(body.error).to.be.a('string').and.not.empty;",
              "  });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
